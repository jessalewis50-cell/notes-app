# Server-side only (dev proxy + Vercel serverless function).
# Never prefix with REACT_APP_ — CRA would inline it into the public client bundle.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Client-safe values (the anon key is designed to be public; access is enforced by RLS).
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

DISABLE_ESLINT_PLUGIN=true
